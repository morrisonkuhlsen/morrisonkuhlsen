---
layout: null
---
[
  {% assign all_posts = site.posts %}
  {% assign all_pages = site.pages | where_exp: "p", "p.title != nil" | where_exp: "p", "p.layout != nil" | where_exp: "p", "p.layout != 'null'" %}
  {% assign counter = 0 %}
  {% assign all_items_size = all_posts.size | plus: all_pages.size %}

  {% for post in all_posts %}
  {% assign counter = counter | plus: 1 %}
  {
    "id": {{ counter }},
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "excerpt": {{ post.excerpt | strip_html | truncatewords: 40 | jsonify }},
    "lang": {{ post.lang | jsonify }},
    "date": {{ post.date | date: "%d/%m/%Y" | jsonify }},
    "type": "post"
  },
  {% endfor %}

  {% for page in all_pages %}
  {% assign counter = counter | plus: 1 %}
  {
    "id": {{ counter }},
    "title": {{ page.title | jsonify }},
    "url": {{ page.url | relative_url | jsonify }},
    "excerpt": {{ page.content | strip_html | truncatewords: 40 | jsonify }},
    "lang": {{ page.lang | jsonify }},
    "date": "",
    "type": "page"
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
